<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme — Material 3 -->
    <style name="Base.Theme.SmartCooking" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">@color/primary_light</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <item name="colorSecondaryContainer">@color/secondary_light</item>

        <!-- Tertiary -->
        <item name="colorTertiary">@color/tertiary</item>
        <item name="colorTertiaryContainer">@color/tertiary_light</item>

        <!-- Background & Surface -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>

        <!-- Error -->
        <item name="colorError">@color/error</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/nav_background</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Ripple -->
        <item name="android:colorControlHighlight">#20D4621A</item>
    </style>

    <style name="Theme.SmartCooking" parent="Base.Theme.SmartCooking" />

    <!-- Splash Screen Theme -->
    <style name="Theme.SmartCooking.Splash" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/splash_bg</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Auth Screen Theme (Transparent status bar) -->
    <style name="Theme.SmartCooking.Auth" parent="Theme.SmartCooking">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Detail Screen Theme -->
    <style name="Theme.SmartCooking.Detail" parent="Theme.SmartCooking">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- ─── Text Appearances ─── -->
    <!-- Base text appearance style to resolve AAPT2 implicit parent requirements -->
    <style name="TextAppearance.SmartCooking" parent="android:TextAppearance" />

    <style name="TextAppearance.SmartCooking.Display">
        <item name="android:textSize">@dimen/text_display</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.SmartCooking.H1">
        <item name="android:textSize">@dimen/text_h1</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.SmartCooking.H2">
        <item name="android:textSize">@dimen/text_h2</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.SmartCooking.H3">
        <item name="android:textSize">@dimen/text_h3</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.SmartCooking.Body">
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.SmartCooking.BodyLarge">
        <item name="android:textSize">@dimen/text_body_lg</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.SmartCooking.Label">
        <item name="android:textSize">@dimen/text_label</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.SmartCooking.Caption">
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- ─── Widget Styles ─── -->
    <style name="Widget.SmartCooking.Button" parent="Widget.Material3.Button">
        <item name="android:textSize">@dimen/text_label</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">@dimen/radius_md</item>
    </style>

    <style name="Widget.SmartCooking.Card" parent="Widget.Material3.CardView.Outlined">
        <item name="cardCornerRadius">@dimen/radius_lg</item>
        <item name="cardElevation">@dimen/elevation_sm</item>
    </style>

</resources>