<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme - Material 3 -->
    <style name="Base.Theme.SmartCooking" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Brand Colors -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Surface & Control colors -->
        <item name="colorSurface">@color/surface</item>
        <item name="colorSurfaceVariant">@color/primary_light</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>

        <!-- Typography Color Defaults -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <style name="Theme.SmartCooking" parent="Base.Theme.SmartCooking" />

    <!-- Style cho Splash Screen -->
    <style name="Theme.SmartCooking.Splash" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/background</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <!-- Modern Card Style -->
    <style name="SavorSmartCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/surface</item>
    </style>

    <!-- Rounded Button Style -->
    <style name="SavorSmartButton" parent="Widget.Material3.Button">
        <item name="cornerRadius">16dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
</resources>