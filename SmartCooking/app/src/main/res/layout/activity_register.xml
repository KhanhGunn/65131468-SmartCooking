<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <Space
            android:layout_width="match_parent"
            android:layout_height="30dp" />

        <!-- Logo Section -->
        <LinearLayout
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:background="@drawable/bg_logo_container"
            android:backgroundTint="@color/accent"
            android:elevation="6dp"
            android:gravity="center"
            android:padding="12dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_utensils"
                app:tint="@color/white"
                android:contentDescription="@string/app_logo_desc" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="sans-serif-black"
            android:text="@string/register_title"
            android:textColor="@color/text_primary"
            android:textSize="30sp"
            android:letterSpacing="-0.02" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/register_tagline"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:fontFamily="sans-serif" />

        <!-- Register Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Full Name Input Group -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_full_name"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium" />

                <EditText
                    android:id="@+id/etFullName"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_edittext"
                    android:drawableStart="@android:drawable/ic_menu_myplaces"
                    android:drawablePadding="14dp"
                    android:hint="@string/hint_full_name"
                    android:inputType="textPersonName"
                    android:paddingHorizontal="18dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="#94A3B8"
                    android:textSize="14sp"
                    android:importantForAutofill="no" />

                <!-- Email Input Group -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/label_email"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium" />

                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_edittext"
                    android:drawableStart="@android:drawable/ic_dialog_email"
                    android:drawablePadding="14dp"
                    android:hint="@string/hint_email"
                    android:inputType="textEmailAddress"
                    android:paddingHorizontal="18dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="#94A3B8"
                    android:textSize="14sp"
                    android:importantForAutofill="no" />

                <!-- Wrapper hỗ trợ Password Toggle cho Mật khẩu -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    app:passwordToggleEnabled="true"
                    app:passwordToggleTint="@color/text_secondary"
                    app:hintEnabled="false"
                    app:boxBackgroundMode="none">

                    <EditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:background="@drawable/bg_edittext"
                        android:drawableStart="@android:drawable/ic_lock_idle_lock"
                        android:drawablePadding="14dp"
                        android:hint="@string/hint_create_password"
                        android:inputType="textPassword"
                        android:paddingHorizontal="18dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="#94A3B8"
                        android:textSize="14sp"
                        android:importantForAutofill="no" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Confirm Password Input Group -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/label_confirm_password"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium" />

                <!-- Wrapper hỗ trợ Password Toggle cho Xác nhận mật khẩu -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    app:passwordToggleEnabled="true"
                    app:passwordToggleTint="@color/text_secondary"
                    app:hintEnabled="false"
                    app:boxBackgroundMode="none">

                    <EditText
                        android:id="@+id/etConfirmPassword"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:background="@drawable/bg_edittext"
                        android:drawableStart="@android:drawable/ic_lock_idle_lock"
                        android:drawablePadding="14dp"
                        android:hint="@string/hint_confirm_password"
                        android:inputType="textPassword"
                        android:paddingHorizontal="18dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="#94A3B8"
                        android:textSize="14sp"
                        android:importantForAutofill="no" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Submit Button -->
                <Button
                    android:id="@+id/btnRegister"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_button"
                    android:text="@string/btn_register"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="17sp"
                    android:fontFamily="sans-serif-bold"
                    app:backgroundTint="@null" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tvLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            android:text="@string/already_have_account"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:fontFamily="sans-serif"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>
</ScrollView>