<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="80dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ===== Inventory Insights Card ===== -->
            <LinearLayout
                android:id="@+id/cardInsights"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_insights_card"
                android:orientation="horizontal"
                android:padding="20dp">

                <!-- Left Content -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-bold"
                        android:text="@string/inventory_insights_title"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:lineSpacingExtra="4dp"
                        android:text="@string/inventory_insights_desc"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/btnGenerateRecipe"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_generate_button"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:paddingHorizontal="20dp"
                        android:text="@string/btn_generate_recipe"
                        android:textColor="@color/white"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- Right Warning Icon -->
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="top"
                    android:layout_marginStart="8dp"
                    android:contentDescription="Warning"
                    android:src="@drawable/ic_warning_triangle" />
            </LinearLayout>

            <!-- ===== Total Items Logged Card ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_total_items_card"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingVertical="24dp">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:contentDescription="Total Items"
                    android:src="@drawable/ic_clipboard" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="sans-serif-black"
                    android:text="@string/total_items_count"
                    android:textColor="@color/text_primary"
                    android:textSize="36sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/total_items_label"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- ===== Vegetables Section ===== -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:fontFamily="sans-serif-bold"
                    android:text="@string/category_vegetables"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/tvViewAllVegetables"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/label_view_all"
                    android:textColor="@color/accent"
                    android:textSize="14sp" />
            </RelativeLayout>

            <!-- Vegetables Grid - 2 columns -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <!-- Item 1: Cherry Tomatoes - Fresh -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardCherryTomatoes"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Image Area with Badge -->
                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="130dp">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="#FFCCBC"
                                android:contentDescription="@string/item_cherry_tomatoes_full"
                                android:scaleType="centerCrop"
                                android:src="@drawable/ic_utensils" />

                            <!-- Fresh Badge -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="top|end"
                                android:layout_margin="8dp"
                                android:background="@drawable/bg_badge_fresh"
                                android:fontFamily="sans-serif-medium"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="4dp"
                                android:text="@string/label_fresh"
                                android:textColor="@color/white"
                                android:textSize="11sp" />
                        </FrameLayout>

                        <!-- Info Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="10dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="sans-serif-medium"
                                    android:text="@string/item_cherry_tomatoes"
                                    android:textColor="@color/text_primary"
                                    android:textSize="14sp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="@string/item_cherry_tomatoes_qty"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="12sp" />
                            </LinearLayout>

                            <ImageView
                                android:id="@+id/btnMoreCherryTomatoes"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:contentDescription="More options"
                                android:src="@drawable/ic_more_vert" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Item 2: Baby Spinach - Use Soon -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardBabySpinach"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Image Area with Badge -->
                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="130dp">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="#C8E6C9"
                                android:contentDescription="@string/item_baby_spinach"
                                android:scaleType="centerCrop"
                                android:src="@drawable/ic_utensils" />

                            <!-- Use Soon Badge -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="top|end"
                                android:layout_margin="8dp"
                                android:background="@drawable/bg_badge_use_soon"
                                android:fontFamily="sans-serif-medium"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="4dp"
                                android:text="@string/label_use_soon"
                                android:textColor="@color/white"
                                android:textSize="11sp" />
                        </FrameLayout>

                        <!-- Info Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="10dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="sans-serif-medium"
                                    android:text="@string/item_baby_spinach"
                                    android:textColor="@color/text_primary"
                                    android:textSize="14sp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="@string/item_baby_spinach_qty"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="12sp" />
                            </LinearLayout>

                            <ImageView
                                android:id="@+id/btnMoreBabySpinach"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:contentDescription="More options"
                                android:src="@drawable/ic_more_vert" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- ===== Proteins Section ===== -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:fontFamily="sans-serif-bold"
                    android:text="@string/category_proteins"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/tvViewAllProteins"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/label_view_all"
                    android:textColor="@color/accent"
                    android:textSize="14sp" />
            </RelativeLayout>

            <!-- Proteins Grid - 2 columns -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <!-- Item 3: Chicken Breast - Expired -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardChickenBreast"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Image Area with Badge -->
                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="130dp">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="#EFEBE9"
                                android:contentDescription="@string/item_chicken_breast"
                                android:scaleType="centerCrop"
                                android:src="@drawable/ic_utensils" />

                            <!-- Expired Badge -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="top|end"
                                android:layout_margin="8dp"
                                android:background="@drawable/bg_badge_expired"
                                android:fontFamily="sans-serif-medium"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="4dp"
                                android:text="@string/label_expired"
                                android:textColor="@color/white"
                                android:textSize="11sp" />
                        </FrameLayout>

                        <!-- Info Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="10dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="sans-serif-medium"
                                    android:text="@string/item_chicken_breast"
                                    android:textColor="@color/text_primary"
                                    android:textSize="14sp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="@string/item_chicken_breast_qty"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="12sp" />
                            </LinearLayout>

                            <ImageView
                                android:id="@+id/btnMoreChickenBreast"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:contentDescription="More options"
                                android:src="@drawable/ic_more_vert" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Item 4: Atlantic Salmon - Fresh -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardAtlanticSalmon"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Image Area with Badge -->
                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="130dp">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="#FFCCBC"
                                android:contentDescription="@string/item_atlantic_salmon_full"
                                android:scaleType="centerCrop"
                                android:src="@drawable/ic_utensils" />

                            <!-- Fresh Badge -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="top|end"
                                android:layout_margin="8dp"
                                android:background="@drawable/bg_badge_fresh"
                                android:fontFamily="sans-serif-medium"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="4dp"
                                android:text="@string/label_fresh"
                                android:textColor="@color/white"
                                android:textSize="11sp" />
                        </FrameLayout>

                        <!-- Info Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="10dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="sans-serif-medium"
                                    android:text="@string/item_atlantic_salmon"
                                    android:textColor="@color/text_primary"
                                    android:textSize="14sp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="@string/item_atlantic_salmon_qty"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="12sp" />
                            </LinearLayout>

                            <ImageView
                                android:id="@+id/btnMoreAtlanticSalmon"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:contentDescription="More options"
                                android:src="@drawable/ic_more_vert" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- ===== Pantry Section ===== -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:fontFamily="sans-serif-bold"
                    android:text="@string/category_pantry"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/tvViewAllPantry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/label_view_all"
                    android:textColor="@color/accent"
                    android:textSize="14sp" />
            </RelativeLayout>

            <!-- Pantry Item 1: Olive Oil -->
            <LinearLayout
                android:id="@+id/cardOliveOil"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_pantry_item_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">

                <!-- Icon Circle -->
                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_pantry_icon" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:contentDescription="Olive Oil"
                        android:src="@drawable/ic_utensils"
                        app:tint="@color/text_secondary" />
                </FrameLayout>

                <!-- Text Info -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/item_olive_oil"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/item_olive_oil_qty"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- More Button -->
                <ImageView
                    android:id="@+id/btnMoreOliveOil"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="More options"
                    android:src="@drawable/ic_more_vert" />
            </LinearLayout>

            <!-- Pantry Item 2: Penne Pasta -->
            <LinearLayout
                android:id="@+id/cardPennePasta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_pantry_item_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">

                <!-- Icon Circle -->
                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_pantry_icon" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:contentDescription="Penne Pasta"
                        android:src="@drawable/ic_utensils"
                        app:tint="@color/text_secondary" />
                </FrameLayout>

                <!-- Text Info -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/item_penne_pasta"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/item_penne_pasta_qty"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- More Button -->
                <ImageView
                    android:id="@+id/btnMorePennePasta"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="More options"
                    android:src="@drawable/ic_more_vert" />
            </LinearLayout>

            <!-- Bottom spacing -->
            <Space
                android:layout_width="match_parent"
                android:layout_height="40dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ===== FAB - Add Item Button ===== -->
    <ImageView
        android:id="@+id/fabAddItem"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_fab"
        android:contentDescription="Add item"
        android:elevation="8dp"
        android:padding="16dp"
        android:src="@drawable/ic_add" />

</FrameLayout>
